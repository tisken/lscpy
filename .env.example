# ============================================================
# LSC - Log Source Checker
# ============================================================
# La mayoría de la configuración se gestiona desde la UI
# (pestaña Configuración): datasources, LLM, Bitbucket, SMTP.
#
# Este fichero solo contiene los valores por defecto del cron
# que se cargan al arrancar la app. Después se pueden cambiar
# desde la pestaña Cron en la UI.
# ============================================================

# Cron automático (defaults al arrancar)
CRON_ENABLED=false
CRON_INTERVAL_MINUTES=60
CRON_HOURS=24
CRON_SIZE=20
CRON_STEP_SEARCH=true
CRON_STEP_ANALYZE=true
CRON_STEP_SEND=false
