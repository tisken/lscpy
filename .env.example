# Elasticsearch
ES_HOST=https://your-elasticsearch:9200
ES_USER=elastic
ES_PASSWORD=<your_password>
ES_INDEX=your-app-logs-*
ES_CA_CERT_PATH=

# Bitbucket Cloud
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_REPO=your-repo
BITBUCKET_BRANCH=main
BITBUCKET_USER=your-user
BITBUCKET_APP_PASSWORD=<your_app_password>

# LLM Provider: bedrock | ollama
LLM_PROVIDER=bedrock

# AWS Bedrock
AWS_REGION=eu-west-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Ollama (opensource local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Email (SMTP) para Jira
SMTP_HOST=smtp.your-company.com
SMTP_PORT=587
SMTP_USER=<your_email>
SMTP_PASSWORD=<your_password>
JIRA_EMAIL=jira-intake@your-company.com
JIRA_PROJECT_KEY=PROJ

# Cron automático
CRON_ENABLED=false
CRON_INTERVAL_MINUTES=60
CRON_HOURS=24
CRON_SIZE=20
CRON_STEP_SEARCH=true
CRON_STEP_ANALYZE=true
CRON_STEP_SEND=false
